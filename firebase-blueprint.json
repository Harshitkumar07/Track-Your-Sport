{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public profile information for a community member.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Community": {
      "title": "Community/Sport Category",
      "description": "A top-level category for sports talk (e.g., NBA, UEFA).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "memberCount": { "type": "integer" }
      },
      "required": ["name"]
    },
    "Thread": {
      "title": "Discussion Thread",
      "description": "A specific topic of discussion within a community.",
      "type": "object",
      "properties": {
        "communityId": { "type": "string" },
        "title": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "messageCount": { "type": "integer" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["communityId", "title", "authorId", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "An individual post or chat message within a thread.",
      "type": "object",
      "properties": {
        "threadId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoURL": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "image"] }
      },
      "required": ["threadId", "authorId", "content", "createdAt"]
    },
    "Post": {
      "title": "Social Post",
      "description": "A global feed post, similar to a tweet.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoURL": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "integer" },
        "comments": { "type": "integer" },
        "likedBy": { "type": "array", "items": { "type": "string" } },
        "sportTag": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["authorId", "authorName", "authorPhotoURL", "content", "createdAt", "likes", "comments", "likedBy"]
    },
    "PostComment": {
      "title": "Post Comment",
      "description": "A comment on a global post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoURL": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by UID."
    },
    "/communities/{communityId}": {
      "schema": "Community",
      "description": "Sports communities."
    },
    "/communities/{communityId}/threads/{threadId}": {
      "schema": "Thread",
      "description": "Threads within a community."
    },
    "/communities/{communityId}/threads/{threadId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a thread."
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Global feed posts."
    },
    "/posts/{postId}/comments/{commentId}": {
      "schema": "PostComment",
      "description": "Comments on global posts."
    }
  }
}
