rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn(); // Relaxed for preview environment reliability
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'createdAt']) 
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 50
        && (data.get('photoURL', '') is string)
        && (data.get('bio', '') is string && data.get('bio', '').size() <= 500)
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && isEmailVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && isEmailVerified()
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && (incoming().get('displayName', '') is string && incoming().get('displayName', '').size() <= 50)
        && (incoming().get('photoURL', '') is string)
        && (incoming().get('bio', '') is string && incoming().get('bio', '').size() <= 500);
    }

    // --- Communities ---
    match /communities/{communityId} {
      allow get, list: if isSignedIn();
      // Allow creation for seeding (demo) or admin
      allow create: if isEmailVerified();
      allow update: if false;

      // --- Threads ---
      function isValidThread(data, commId) {
        return data.keys().hasAll(['communityId', 'title', 'authorId', 'createdAt', 'authorName'])
          && data.communityId == commId
          && data.title is string && data.title.size() > 0 && data.title.size() <= 200
          && (data.authorId == request.auth.uid || data.authorId == 'system')
          && (data.createdAt == request.time || data.authorId == 'system');
      }

      match /threads/{threadId} {
        allow get, list: if isSignedIn();
        allow create: if isEmailVerified() && isValidThread(incoming(), communityId);
        allow update: if isEmailVerified() 
          && (
            // Action: Update message count/lastMessageAt (Relational Sync)
            (incoming().diff(existing()).affectedKeys().hasOnly(['messageCount', 'lastMessageAt']))
            ||
            // Action: Edit thread info by owner
            (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'tags']))
          )
          && incoming().authorId == existing().authorId
          && incoming().communityId == existing().communityId;
        
        // --- Messages ---
        function isValidMessage(data, tId) {
          return data.keys().hasAll(['threadId', 'authorId', 'authorName', 'content', 'createdAt'])
            && data.threadId == tId
            && (data.authorId == request.auth.uid || data.authorId == 'system')
            && data.content is string && data.content.size() > 0 && data.content.size() <= 5000
            && (data.createdAt == request.time || data.authorId == 'system');
        }

        match /messages/{messageId} {
          allow get, list: if isSignedIn();
          allow create: if isEmailVerified() 
            && isValidMessage(incoming(), threadId)
            && exists(/databases/$(database)/documents/communities/$(communityId)/threads/$(threadId));
        }
      }
    }

    // --- Global Posts (The Dugout) ---
    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'authorName', 'authorPhotoURL', 'content', 'createdAt', 'likes', 'comments', 'likedBy'])
        && (data.authorId == request.auth.uid || data.authorId == 'system')
        && data.content is string && data.content.size() > 0 && data.content.size() <= 2000
        && (data.createdAt == request.time || data.authorId == 'system')
        && data.likes is int && data.comments is int
        && (data.get('sportTag', '') is string)
        && (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 1500000)
        && (data.get('authorPhotoURL', '') is string)
        && (data.get('likedBy', []) is list);
    }

    match /posts/{postId} {
      allow get, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidPost(incoming());
      allow update: if isEmailVerified() 
        && (
          // Action: Like/Comment Sync
          (incoming().diff(existing()).affectedKeys().hasAny(['likes', 'comments', 'likedBy']))
          ||
          // Action: Edit by owner
          (isOwner(existing().authorId) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'sportTag', 'imageUrl']))
        )
        && incoming().authorId == existing().authorId;
      allow delete: if isOwner(existing().authorId);

      // --- Post Comments ---
      function isValidPostComment(data) {
        return data.keys().hasAll(['authorId', 'authorName', 'content', 'createdAt'])
          && data.authorId == request.auth.uid
          && data.content is string && data.content.size() > 0 && data.content.size() <= 1000
          && data.createdAt == request.time;
      }

      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isEmailVerified() && isValidPostComment(incoming()) && exists(/databases/$(database)/documents/posts/$(postId));
      }
    }

    // --- Suggestions ---
    match /suggestions/{suggestionId} {
      allow create: if isEmailVerified();
      allow get, list: if false; // Only admins or system
    }
  }
}
